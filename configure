#!/bin/sh

. ./tconf.sh

# defaults
: ${SHARED:=static}
: ${SHARED:=no}
: ${SYSROOT=./sysroot}

tconf_init "$@"

tconf_search_cc "$HOST"
tconf_search_as "$HOST"
tconf_search_ar "$HOST"
tconf_find_os

tconf_check_attribute "$CC" "weak"

ARCH=${HOST%%-*}

tconf_fini
tconf_echo_conf "STATIC" "$STATIC" >> config.mk
tconf_echo_conf "SHARED" "$STATIC" >> config.mk

./tmakegen
