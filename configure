#!/bin/sh

. ./tconf.sh

# defaults
SHARED=no
test -z "$SYSROOT" && SYSROOT=$(realpath ./sysroot)

tconf_init "$@"

tconf_search_cc "$HOST"
tconf_search_as "$HOST"
tconf_search_ar "$HOST"
tconf_find_os

tconf_check_attribute "$CC" "weak"

ARCH=${HOST%%-*}

tconf_fini
echo "SHARED=$SHARED" >> config.mk
